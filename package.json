{
  "name": "market-data-aggregator",
  "version": "0.1.0",
  "description": "Provider-agnostic market data aggregation with SWR caching, health monitoring, rate limiting, and pluggable credential/cache/storage adapters.",
  "type": "module",
  "license": "MIT",
  "author": "Hicham Kazan",
  "keywords": [
    "market-data",
    "stocks",
    "crypto",
    "finance",
    "quotes",
    "dividends",
    "earnings",
    "aggregator",
    "swr",
    "cache",
    "rate-limiting",
    "circuit-breaker"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hicham/market-data-aggregator.git"
  },
  "homepage": "https://github.com/hicham/market-data-aggregator#readme",
  "bugs": {
    "url": "https://github.com/hicham/market-data-aggregator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sqlite": {
      "types": "./dist/sqlite.d.ts",
      "import": "./dist/sqlite.js",
      "require": "./dist/sqlite.cjs"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js",
      "require": "./dist/redis.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run check-types && npm run lint && npm run test && npm run build",
    "verify:package": "bash scripts/verify-package.sh",
    "docs:api": "typedoc"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "yahoo-finance2": "^3.0.0",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11",
    "ioredis": ">=5"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^11.10.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8"
  }
}
