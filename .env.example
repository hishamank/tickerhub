# Provider API keys consumed by the default EnvCredentialProvider.
#
# All keys are OPTIONAL — a provider without its key is skipped, and keyless
# providers (Yahoo Finance, CoinGecko) always work. Copy to `.env` and fill in
# the providers you use. To resolve keys some other way (secrets manager,
# per-user), implement the CredentialProvider port instead.

# Finnhub — https://finnhub.io  (free: 60 req/min)
FINNHUB_API_KEY=

# Financial Modeling Prep — https://site.financialmodelingprep.com  (free: 250 req/day; some endpoints paid)
FMP_API_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key  (free: 5 req/min, 500/day)
ALPHA_VANTAGE_API_KEY=

# Polygon.io — https://polygon.io  (free tier available)
POLYGON_API_KEY=

# Tiingo — https://www.tiingo.com  (free: 500 req/hr)
TIINGO_API_KEY=

# Twelve Data — https://twelvedata.com  (free: 8 req/min, 800/day)
TWELVE_DATA_API_KEY=

# Marketstack — https://marketstack.com  (free: 100 req/month)
MARKETSTACK_API_KEY=

# Tradier — https://developer.tradier.com  (options data; brokerage account)
TRADIER_API_KEY=

# Alpaca — https://alpaca.markets  (key + secret; free market data)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Nasdaq Data Link (formerly Quandl) — https://data.nasdaq.com
NASDAQ_DATA_LINK_API_KEY=

# Keyless (no entry needed): Yahoo Finance, CoinGecko (crypto)
